{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/review-article-gate.sh",
            "timeout": 15,
            "statusMessage": "Verificando se o arquivo é um artigo a revisar..."
          }
        ]
      }
    ]
  }
}
